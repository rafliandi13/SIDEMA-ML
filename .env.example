APP_NAME=SIDEMA-ML API
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

MAX_UPLOAD_SIZE_BYTES=5242880
ALLOWED_IMAGE_MIME_TYPES=["image/jpeg","image/png","image/jpg","image/webp"]
ALLOWED_IMAGE_EXTENSIONS=["jpg","jpeg","png","webp"]
MIN_IMAGE_WIDTH=128
MIN_IMAGE_HEIGHT=128
BLUR_SCORE_THRESHOLD=35.0
BRIGHTNESS_MIN=30.0
BRIGHTNESS_MAX=230.0

MINIO_ENDPOINT=your-minio-host:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_SECURE=false
MINIO_BUCKET_NAME=sidema-raw
MINIO_PUBLIC_BASE_URL=https://your-minio-public-url
MINIO_AUTO_CREATE_BUCKET=false

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Backward compatible (optional): if SUPABASE_SERVICE_ROLE_KEY is filled, this can be empty.
SUPABASE_KEY=
PREDICTIONS_TABLE=predictions

NAIL_MODEL_VERSION=nail-mlp-v1
NAIL_THRESHOLD=0.255
NAIL_MLP_MODEL_PATH=models/nail/mlp_model.joblib
NAIL_SCALER_MODEL_PATH=models/nail/feature_scaler.joblib

CONJUNCTIVA_MODEL_VERSION=conjunctiva-mobilenet-v1
CONJUNCTIVA_THRESHOLD=0.5
CONJUNCTIVA_MODEL_PATH=models/conjunctiva/Model_MobileNet.h5
CONJUNCTIVA_INPUT_SIZE=224

ALLOW_THRESHOLD_OVERRIDE=true
